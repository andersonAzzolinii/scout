{
  "expo": {
    "name": "Scout Futsal",
    "slug": "scout",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.scout.futsal"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.scout.futsal"
    },
    "plugins": [
      "expo-sqlite",
      "expo-asset",
      "expo-font"
    ]
  }
}
