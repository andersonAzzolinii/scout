{
  "expo": {
    "name": "Scout Futsal",
    "slug": "scout",
    "version": "1.2.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.scout.futsal",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1a1a2e"
      },
      "package": "com.scout.futsal"
    },
    "plugins": [
      "expo-sqlite",
      "expo-asset",
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "cd315425-399b-47b0-a93f-a3af7a8179f5"
      }
    }
  }
}
